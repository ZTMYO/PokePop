{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "PokePop",
  "version": "0.1.0",
  "identifier": "com.pokepop.desktop",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "PokePop",
        "label": "main",
        "width": 320,
        "height": 400,
        "resizable": false,
        "fullscreen": false,
        "transparent": true,
        "alwaysOnTop": true,
        "decorations": false,
        "skipTaskbar": true,
        "visible": false,
        "dragDropEnabled": true,
        "focusable": true,
        "maximizable": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "resources": {
      "../src/pokemon-data/images": "pokemon-data/images"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installMode": "currentUser",
        "compression": "lzma",
        "languages": ["SimpChinese"],
        "displayLanguageSelector": false
      }
    }
  }
}
